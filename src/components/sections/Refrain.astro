---
import type { Locale } from '../../config/site';
import { getStrings } from '../../i18n/t';
import { Plus, PenLine, Activity, CheckCircle2 } from 'lucide-astro';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = getStrings(locale);

const icons = [Plus, PenLine, Activity, CheckCircle2];
---

<section class="refrain" aria-labelledby="refrain-headline">
  <div class="container refrain-inner">
    <h2 id="refrain-headline" class="headline">{t.refrain.headline}</h2>
    <span class="underline" aria-hidden="true"></span>

    <ol class="steps">
      {t.refrain.steps.map((step, i) => {
        const Icon = icons[i];
        return (
          <li>
            <Icon size={22} />
            <span>{step}</span>
          </li>
        );
      })}
    </ol>
  </div>
</section>

<style>
  .refrain {
    padding-block: var(--space-3xl);
    background: linear-gradient(180deg, var(--bg) 0%, color-mix(in oklab, var(--bg), white 2%) 50%, var(--bg) 100%);
    text-align: center;
  }

  .headline {
    font-family: var(--font-serif);
    font-weight: 200;
    font-size: var(--font-display-2);
    letter-spacing: 0.02em;
    line-height: 1.15;
    margin: 0 auto var(--space-lg);
    max-width: 22ch;
    color: var(--text-primary);
  }

  .underline {
    display: block;
    width: 120px;
    height: 1px;
    background: var(--gold);
    margin: var(--space-md) auto var(--space-2xl);
    opacity: 0.6;
  }

  .steps {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-2xl);
    color: var(--text-secondary);
    flex-wrap: wrap;
  }

  .steps li {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--font-caption);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .steps :global(svg) { color: var(--gold); }
</style>
