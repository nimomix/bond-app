---
import type { Locale } from '../../config/site';
import { getStrings } from '../../i18n/t';
import DownloadButtons from '../DownloadButtons.astro';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = getStrings(locale);
---

<section id="coming-soon" class="cs" aria-labelledby="cs-headline">
  <div class="container cs-inner">
    <p class="eyebrow">{t.comingSoon.eyebrow}</p>
    <h2 id="cs-headline" class="headline">{t.comingSoon.headline}</h2>
    <p class="subhead">{t.comingSoon.subhead}</p>

    <DownloadButtons locale={locale} align="center" />

    <p class="notify">
      {t.comingSoon.notify}
      <a href="mailto:nimoapps25@gmail.com">{t.comingSoon.notifyLink}</a>
    </p>
  </div>
</section>

<style>
  .cs {
    padding-block: var(--space-3xl);
    text-align: center;
    background:
      radial-gradient(ellipse at center top, rgba(212, 165, 116, 0.06), transparent 60%),
      var(--bg);
  }

  .cs-inner {
    max-width: 720px;
    display: grid;
    gap: var(--space-md);
    justify-items: center;
  }

  .eyebrow {
    font-size: var(--font-micro);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gold);
    margin: 0;
  }

  .headline {
    font-family: var(--font-sans);
    font-weight: 200;
    font-size: var(--font-display-2);
    line-height: 1.1;
    margin: 0;
    color: var(--text-primary);
  }

  .subhead {
    font-size: var(--font-headline);
    color: var(--text-secondary);
    margin: 0 0 var(--space-lg);
  }

  .notify {
    margin-top: var(--space-lg);
    font-size: var(--font-caption);
    color: var(--text-muted);
  }

  .notify a { color: var(--gold); }
</style>
