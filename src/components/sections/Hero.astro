---
import { SITE_BASE, type Locale } from '../../config/site';
import { getStrings } from '../../i18n/t';
import PhoneFrame from '../PhoneFrame.astro';
import DownloadButtons from '../DownloadButtons.astro';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = getStrings(locale);
---

<section class="hero" aria-labelledby="hero-tagline">
  <div class="container hero-grid">
    <div class="hero-text">
      <p class="wordmark" aria-hidden="true">{t.hero.wordmark}</p>
      <h1 id="hero-tagline" class="tagline">{t.hero.tagline}</h1>
      <p class="subhead">{t.hero.subhead}</p>
      <DownloadButtons locale={locale} align="start" />
      <p class="hint">{t.hero.downloadHint}</p>
    </div>

    <div class="hero-visual">
      <PhoneFrame
        src={`${SITE_BASE}/screenshots/hero-signed.png`}
        alt={t.hero_image_alt}
        tilt={5}
        glow
        width={300}
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-3xl) var(--space-2xl);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: -20% -10% auto -10%;
    height: 80%;
    background: radial-gradient(ellipse at top, rgba(212, 165, 116, 0.06), transparent 60%);
    pointer-events: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .hero-text {
    display: grid;
    gap: var(--space-lg);
  }

  .wordmark {
    font-family: var(--font-script);
    color: var(--gold);
    font-size: clamp(64px, 9vw, 128px);
    line-height: 1;
    margin: 0;
  }

  .tagline {
    font-family: var(--font-serif);
    font-weight: 200;
    font-size: var(--font-display-1);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--text-primary);
  }

  .subhead {
    font-size: var(--font-headline);
    color: var(--text-secondary);
    max-width: 52ch;
    margin: 0;
  }

  .hint {
    font-size: var(--font-caption);
    color: var(--text-muted);
    margin: 0;
  }

  .hero-visual {
    display: grid;
    place-items: center;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
    .hero-visual {
      order: 2;
    }
  }
</style>
