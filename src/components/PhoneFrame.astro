---
interface Props {
  src: string;
  alt: string;
  tilt?: number;       // degrees
  glow?: boolean;
  width?: number;      // logical width in px (frame, not image)
}

const { src, alt, tilt = 0, glow = false, width = 280 } = Astro.props;
---

<div class:list={["phone", { glow }]} style={`--tilt:${tilt}deg; --w:${width}px;`}>
  <div class="phone-frame">
    <div class="notch" aria-hidden="true"></div>
    <img src={src} alt={alt} loading="lazy" decoding="async" />
  </div>
</div>

<style>
  .phone {
    width: var(--w);
    aspect-ratio: 19.5 / 40;
    transform: rotate(var(--tilt));
    transition: transform 0.4s ease;
    position: relative;
    margin-inline: auto;
  }

  .phone-frame {
    position: relative;
    width: 100%;
    height: 100%;
    background: #050505;
    border: 1px solid var(--border);
    border-radius: 36px;
    box-shadow:
      inset 0 0 0 2px rgba(255, 255, 255, 0.04),
      0 30px 80px rgba(0, 0, 0, 0.6);
    padding: 8px;
    overflow: hidden;
  }

  .notch {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    width: 36%;
    height: 22px;
    background: #050505;
    border-radius: 999px;
    z-index: 1;
  }

  .phone-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 28px;
  }

  .phone.glow::before {
    content: "";
    position: absolute;
    inset: -40px;
    background: radial-gradient(closest-side, rgba(212, 165, 116, 0.18), transparent 70%);
    z-index: -1;
    pointer-events: none;
  }

  .phone:hover {
    transform: rotate(0deg);
  }

  /* Mirror tilt direction in RTL so the phone stays inward-leaning */
  :global([dir="rtl"]) .phone {
    transform: rotate(calc(var(--tilt) * -1));
  }
  :global([dir="rtl"]) .phone:hover {
    transform: rotate(0deg);
  }
</style>
