---
import { SITE_BASE } from '../config/site';
const home = `${SITE_BASE}/en/`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Not Found — Bond</title>
    <style>
      body { background:#0c0a09; color:#e7e5e4; font-family: -apple-system, system-ui, sans-serif; min-height:100vh; display:grid; place-items:center; margin:0; }
      .wrap { text-align:center; padding:32px; }
      a { color:#d4a574; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <h1 style="font-weight:200; font-size:48px; margin:0 0 16px;">404</h1>
      <p>This page doesn't exist.</p>
      <p><a href={home}>Back to Bond</a></p>
    </div>
  </body>
</html>
